{
  "manifest_version": 2,
  "name": "noet",
  "version": "0.3.0",
  "description": "Открывает имена noet прямо в адресной строке браузера. Клик по иконке — вкл/выкл.",
  "permissions": ["proxy", "storage"],
  "background": {
    "scripts": ["background.firefox.js"],
    "persistent": true
  },
  "browser_action": {
    "default_title": "noet (клик: вкл/выкл)",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "noet@noet-scz",
      "strict_min_version": "91.0",
      "update_url": "https://noet-scz.github.io/noet/dist/updates.firefox.json"
    }
  }
}
