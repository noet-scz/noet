{
  "manifest_version": 3,
  "name": "noet",
  "version": "1.0.0",
  "description": "Свободный интернет в твоём браузере: сайты, которые нельзя заблокировать, удалить или отобрать.",
  "permissions": ["webNavigation", "tabs", "storage"],
  "background": { "service_worker": "bg.js" },
  "icons": { "16": "icons/icon-16.png", "32": "icons/icon-32.png", "48": "icons/icon-48.png", "128": "icons/icon-128.png" },
  "action": {
    "default_title": "noet",
    "default_icon": { "16": "icons/icon-16.png", "32": "icons/icon-32.png", "48": "icons/icon-48.png", "128": "icons/icon-128.png" }
  },
  "web_accessible_resources": [
    { "resources": ["view.html", "view.js", "config.default.json", "app/*", "vendor/*"], "matches": ["<all_urls>"] }
  ]
}
